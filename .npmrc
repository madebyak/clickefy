link-workspace-packages=true
prefer-workspace-packages=true
auto-install-peers=true
strict-peer-dependencies=false
verify-deps-before-run=false

# Expo / React Native need a flat node_modules layout to avoid duplicate
# React copies. This makes pnpm install per-app deps as direct folders
# (like npm or yarn would) instead of using symlinks. Next.js in apps/admin
# is unaffected by this.
node-linker=hoisted
