# Clerk — publishable key MUST be prefixed NEXT_PUBLIC_ to reach the browser bundle.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cloudflare Worker API base URL — browser-exposed (no secrets).
NEXT_PUBLIC_API_URL=https://clickfy-api.clickefy-ai.workers.dev

# ── AI provider keys (Playground only) ─────────────────────────────────
# The admin Playground calls Gemini / Kling directly via @clickfy/providers
# so admins can iterate without round-tripping through the Worker. Mobile
# jobs still go through the Worker; same keys live in apps/api/.dev.vars.
GEMINI_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
