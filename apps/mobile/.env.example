# Variables prefixed EXPO_PUBLIC_ are inlined into the JS bundle at build time.

# Clerk publishable key (safe to ship to client).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Override the default API base URL (set in app.json -> extra.apiUrl).
# - iOS Simulator: leave blank (defaults to http://localhost:8787)
# - Android Emulator: http://10.0.2.2:8787
# - Physical phone on same Wi-Fi: http://<your-mac-LAN-IP>:8787
# EXPO_PUBLIC_API_URL=
