{
  "expo": {
    "name": "Clickefy",
    "slug": "clickfy",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clickfy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ai.clickfy.app",
      "supportsTablet": false
    },
    "android": {
      "package": "ai.clickfy.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A10",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A10",
          "dark": {
            "backgroundColor": "#0A0A10"
          }
        }
      ],
      "expo-video",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Clickefy needs access to save the images and videos you generate to your photo library.",
          "savePhotosPermission": "Clickefy needs permission to save the images and videos you generate to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "demoMode": false,
      "router": {},
      "eas": {
        "projectId": "9b1cf22e-a85b-4586-b0f5-0402bb9e6912"
      }
    },
    "owner": "moonswhale",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b1cf22e-a85b-4586-b0f5-0402bb9e6912"
    }
  }
}
