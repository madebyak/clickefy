{
  "expo": {
    "name": "Clickefy",
    "slug": "clickfy",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clickfy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ai.clickfy.app",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "LSApplicationCategoryType": "public.app-category.photography"
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1",
              "0A2A.1",
              "3B52.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1",
              "85F4.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "ai.clickfy.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A10",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A10",
          "dark": {
            "backgroundColor": "#0A0A10"
          }
        }
      ],
      "expo-video",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Clickefy reads your photo library so you can use existing photos as inputs for AI generation.",
          "savePhotosPermission": "Clickefy needs permission to save your generated images and videos to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Clickefy reads your photo library so you can use existing photos as inputs for AI generation.",
          "cameraPermission": "Clickefy uses the camera so you can capture product photos to use as input for AI generation.",
          "microphonePermission": "Clickefy uses the microphone if you record video inputs for AI generation."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#7C3AED",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "demoMode": false,
      "router": {},
      "eas": {
        "projectId": "9b1cf22e-a85b-4586-b0f5-0402bb9e6912"
      }
    },
    "owner": "moonswhale",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b1cf22e-a85b-4586-b0f5-0402bb9e6912"
    }
  }
}
