{
  "name": "clickfy",
  "private": true,
  "version": "0.0.0",
  "description": "Clickfy monorepo — admin dashboard, mobile app, and API.",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:admin": "pnpm --filter @clickfy/admin dev",
    "dev:api": "pnpm --filter @clickfy/api dev",
    "dev:mobile": "pnpm --filter @clickfy/mobile dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "msw",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "esbuild",
      "workerd"
    ]
  }
}
