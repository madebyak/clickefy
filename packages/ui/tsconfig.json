{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@clickfy/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["react", "react-native"]
  },
  "include": ["src/**/*"]
}
